@model IEnumerable<MyCodeManager.Models.Snippet>

@{
    ViewData["Title"] = ViewData["CurrentFilter"] ?? "All Snippets";
}

<style>
    .snippet-card {
        background-color: #1e1e1e; border: 1px solid #333;
        border-radius: 10px; transition: transform 0.2s, border-color 0.2s;
        height: 100%; position: relative;
    }
    .snippet-card:hover { transform: translateY(-3px); border-color: #007acc; }

    .card-title { color: #d4d4d4; font-weight: 600; margin-right: 60px; /* مسافة للأزرار */ }
    .card-lang-text { color: #9cdcfe; font-size: 0.85rem; }

    .code-preview {
        background-color: #000000; color: #ce9178;
        font-family: 'Consolas', monospace; font-size: 0.8rem;
        padding: 12px; border-radius: 6px; height: 110px;
        overflow: hidden; margin-top: 10px; opacity: 0.9; position: relative;
    }

    /* أزرار الإجراءات (النجمة والمشاركة) */
    .action-buttons {
        position: absolute; top: 15px; right: 15px;
        display: flex; gap: 10px; z-index: 10;
    }
    .action-btn {
        background: none; border: none; font-size: 1.2rem; 
        cursor: pointer; transition: transform 0.2s; text-decoration: none;
    }
    .action-btn:hover { transform: scale(1.2); }
    
    .star-filled { color: #f1c40f; } .star-empty { color: #444; }
    .share-public { color: #2ecc71; } .share-private { color: #444; }

    .copy-btn {
        position: absolute; top: 5px; right: 5px;
        background-color: rgba(255,255,255,0.1); border: none; color: #bbb;
        font-size: 0.7rem; padding: 4px 8px; border-radius: 4px; cursor: pointer;
        display: none;
    }
    .code-preview:hover .copy-btn { display: block; }
    .copy-btn:hover { background-color: #007acc; color: white; }

    .bg-indigo { background-color: #a29bfe; color: black; }
</style>

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h2 class="text-white ps-2 border-start border-4 border-primary m-0">@ViewData["Title"]</h2>
    </div>
    <div class="col-md-6 mt-3 mt-md-0" style="position: relative;">
        <div class="input-group">
            <input type="text" id="liveSearchInput" class="form-control bg-dark text-white border-secondary" placeholder="Live search by title or language..." autocomplete="off">
            <span class="input-group-text bg-primary border-primary text-white"><i class="fas fa-bolt"></i></span>
        </div>
        
        <ul id="searchResultsBox" class="dropdown-menu dropdown-menu-dark w-100 shadow-lg mt-1" style="display:none; position:absolute; z-index: 1000;">
            </ul>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center mt-5 pt-5 opacity-50">
        <i class="fas fa-box-open fa-5x mb-3 text-secondary"></i>
        <h4 class="text-muted">No Snippets Found</h4>
        <a asp-action="Create" class="btn btn-outline-primary mt-2">Create First Snippet</a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            var badgeColor = "bg-secondary";
            if (item.Language == "C#") { badgeColor = "bg-csharp"; }
            else if (item.Language == "JavaScript") { badgeColor = "bg-js"; }
            else if (item.Language == "HTML" || item.Language == "HTML/CSS") { badgeColor = "bg-html"; }
            else if (item.Language == "SQL") { badgeColor = "bg-sql"; }
            else if (item.Language == "Java") { badgeColor = "bg-danger"; }
            else if (item.Language == "Kotlin") { badgeColor = "bg-indigo"; }

            <div class="col-md-4">
                <div class="snippet-card p-3">

                    <div class="action-buttons">
                        <a asp-action="ToggleSharing" asp-route-id="@item.Id" class="action-btn" title="@(item.IsPublic ? "Make Private" : "Make Public")">
                            @if (item.IsPublic) { <i class="fas fa-globe share-public"></i> }
                            else { <i class="fas fa-lock share-private"></i> }
                        </a>

                        <a asp-action="ToggleFavorite" asp-route-id="@item.Id" class="action-btn" title="Toggle Favorite">
                            @if (item.IsFavorite) { <i class="fas fa-star star-filled"></i> }
                            else { <i class="far fa-star star-empty"></i> }
                        </a>
                    </div>

                    <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                        <h5 class="card-title text-truncate">@item.Title</h5>

                        <div class="d-flex align-items-center mb-2">
                            <span class="nav-icon-circle @badgeColor d-inline-flex">
                                @if(item.Language == "JavaScript") { <span>JS</span> }
                                else if (item.Language == "HTML" || item.Language == "HTML/CSS") { <span>H</span> }
                                else if (item.Language == "SQL") { <span>SL</span> }
                                else if (item.Language == "Java") { <span>J</span> }
                                else if (item.Language == "Kotlin") { <span>K</span> }
                                else { <span>C#</span> }
                            </span>
                            <span class="card-lang-text">@(item.Language == "HTML" ? "HTML/CSS" : item.Language)</span>
                        </div>

                        @if(item.IsPublic && !string.IsNullOrEmpty(item.ShareToken))
                        {
                            <div class="input-group input-group-sm mt-2 mb-2" onclick="event.preventDefault();">
                                <span class="input-group-text bg-dark border-secondary text-success"><i class="fas fa-link"></i></span>
                                <input type="text" class="form-control bg-dark border-secondary text-info" style="font-size: 0.75rem;" 
                                       value="@Url.Action("Share", "Snippets", new { token = item.ShareToken }, Context.Request.Scheme)" 
                                       readonly id="shareLink_@item.Id">
                                <button class="btn btn-outline-secondary" type="button" onclick="copyShareLink('shareLink_@item.Id', this)">
                                    <i class="far fa-copy"></i>
                                </button>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(item.Description))
                        {
                            <p class="text-muted small mb-2 text-truncate">@item.Description</p>
                        }

                        <div class="code-preview">
                            <button class="copy-btn" onclick="copyToClipboard(this, `@item.Code`)" title="Copy Code">
                                <i class="far fa-copy"></i> Copy
                            </button>
                            <pre style="margin: 0; white-space: pre-wrap;"><code class="language-@item.Language.Replace("#", "sharp")" style="background: transparent; padding: 0;">@item.Code</code></pre>
                        </div>
                    </a>
                </div>
            </div>
        }
    </div>
}

<script>
    // نسخ الكود العادي
    function copyToClipboard(btn, text) {
        event.preventDefault(); event.stopPropagation();
        navigator.clipboard.writeText(text).then(function() {
            let originalContent = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
            btn.classList.add('text-success');
            setTimeout(function() { btn.innerHTML = originalContent; btn.classList.remove('text-success'); }, 2000);
        });
    }

    // نسخ رابط المشاركة العام
    function copyShareLink(inputId, btn) {
        event.preventDefault(); event.stopPropagation();
        var copyText = document.getElementById(inputId);
        copyText.select();
        copyText.setSelectionRange(0, 99999); /* للموبايل */
        navigator.clipboard.writeText(copyText.value).then(function() {
            let originalContent = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check text-success"></i>';
            setTimeout(function() { btn.innerHTML = originalContent; }, 2000);
            
            Swal.fire({
                toast: true, position: 'top-end', icon: 'success',
                title: 'Public Link Copied!', showConfirmButton: false, 
                timer: 2000, background: '#1e1e1e', color: '#fff'
            });
        });
    }

    // === الإضافة الجديدة: كود البحث الذكي (Live Search API) ===
    const searchInput = document.getElementById('liveSearchInput');
    const resultsBox = document.getElementById('searchResultsBox');

    if (searchInput) {
        searchInput.addEventListener('input', async function (e) {
            const term = e.target.value.trim();
            
            // إذا كان المربع فارغاً، نخفي القائمة
            if (term.length === 0) {
                resultsBox.style.display = 'none';
                return;
            }

            try {
                // إرسال الطلب للـ API
                const response = await fetch(`/api/snippets/search?term=${term}`);
                const data = await response.json(); 

                // مسح النتائج القديمة
                resultsBox.innerHTML = '';
                
                if (data.length > 0) {
                    data.forEach(item => {
                        resultsBox.innerHTML += `
                            <li>
                                <a class="dropdown-item d-flex align-items-center py-2" href="/Snippets/Details/${item.id}">
                                    <span class="badge bg-secondary me-2" style="width: 50px;">${item.language}</span> 
                                    <span class="text-truncate">${item.title}</span>
                                </a>
                            </li>`;
                    });
                    resultsBox.style.display = 'block'; 
                } else {
                    resultsBox.innerHTML = '<li class="dropdown-item text-muted text-center py-2">No results found</li>';
                    resultsBox.style.display = 'block';
                }
            } catch (error) {
                console.error("API Error:", error);
            }
        });

        // إخفاء القائمة عند النقر في أي مكان آخر بالشاشة
        document.addEventListener('click', function(e) {
            if (e.target !== searchInput) {
                resultsBox.style.display = 'none';
            }
        });
    }
</script>