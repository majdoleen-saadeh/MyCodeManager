@model MyCodeManager.Models.Snippet

@{
    ViewData["Title"] = "Create Snippet";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card bg-dark border-secondary shadow">
            <div class="card-header border-secondary">
                <h4 class="text-white m-0"><i class="fas fa-plus-circle text-primary me-2"></i> Add New Snippet</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="form-group mb-3">
                        <label asp-for="Title" class="control-label text-white mb-2 fw-bold"></label>
                        <input asp-for="Title" class="form-control bg-dark text-white border-secondary" placeholder="e.g. User Authentication Function" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Language" class="control-label text-white mb-2 fw-bold"><i class="fas fa-code"></i> Language</label>
                        
                        <select id="languageDropdown" class="form-select bg-dark text-white border-secondary" onchange="handleLanguageChange()">
                            <option value="C#">C#</option>
                            <option value="JavaScript">JavaScript</option>
                            <option value="HTML">HTML/CSS</option>
                            <option value="SQL">SQL</option>
                            <option value="Java">Java</option>
                            <option value="Kotlin">Kotlin</option>
                            <option value="custom" class="text-info fw-bold">➕ Add New Language... (لغة أخرى)</option>
                        </select>

                        <input asp-for="Language" id="Language" class="form-control bg-dark text-info border-secondary mt-2" style="display: none;" placeholder="Type your custom language here (e.g. Python, Go)..." />
                        <span asp-validation-for="Language" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Description" class="control-label text-white mb-2 fw-bold"></label>
                        <textarea asp-for="Description" class="form-control bg-dark text-white border-secondary" rows="2" placeholder="Brief description of what this code does..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Code" class="control-label text-white mb-2 fw-bold"></label>
                        <textarea asp-for="Code" class="form-control bg-black text-warning border-secondary" rows="8" style="font-family: 'Consolas', monospace;" placeholder="Paste your code here..."></textarea>
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>

                    <div class="form-group d-flex gap-2">
                        <button type="submit" class="btn btn-primary fw-bold px-4"><i class="fas fa-save me-1"></i> Save Vault</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function handleLanguageChange() {
            var dropdown = document.getElementById("languageDropdown");
            var realInput = document.getElementById("Language");

            if (dropdown.value === "custom") {
                realInput.style.display = "block";
                realInput.value = "";
                realInput.focus();
            } else {
                realInput.style.display = "none";
                realInput.value = dropdown.value;
            }
        }

        document.addEventListener("DOMContentLoaded", function() {
            var dropdown = document.getElementById("languageDropdown");
            var realInput = document.getElementById("Language");
            realInput.value = dropdown.value;
        });
    </script>
}