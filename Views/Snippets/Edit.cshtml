@model MyCodeManager.Models.Snippet

@{
    ViewData["Title"] = "Edit Snippet";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card bg-dark border-secondary shadow">
            <div class="card-header border-secondary">
                <h4 class="text-white m-0"><i class="fas fa-edit text-warning me-2"></i> Edit Snippet</h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <input type="hidden" asp-for="IsFavorite" />
                    <input type="hidden" asp-for="IsPublic" />
                    <input type="hidden" asp-for="ShareToken" />

                    <div class="form-group mb-3">
                        <label asp-for="Title" class="control-label text-white mb-2 fw-bold"></label>
                        <input asp-for="Title" class="form-control bg-dark text-white border-secondary" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Language" class="control-label text-white mb-2 fw-bold"><i class="fas fa-code"></i> Language</label>
                        
                        <select id="languageDropdown" class="form-select bg-dark text-white border-secondary" onchange="handleLanguageChange()">
                            <option value="C#">C#</option>
                            <option value="JavaScript">JavaScript</option>
                            <option value="HTML">HTML/CSS</option>
                            <option value="SQL">SQL</option>
                            <option value="Java">Java</option>
                            <option value="Kotlin">Kotlin</option>
                            <option value="custom" class="text-info fw-bold">➕ Add New Language... (لغة أخرى)</option>
                        </select>

                        <input asp-for="Language" id="Language" class="form-control bg-dark text-info border-secondary mt-2" style="display: none;" placeholder="Type your custom language here..." />
                        <span asp-validation-for="Language" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Description" class="control-label text-white mb-2 fw-bold"></label>
                        <textarea asp-for="Description" class="form-control bg-dark text-white border-secondary" rows="2"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Code" class="control-label text-white mb-2 fw-bold"></label>
                        <textarea asp-for="Code" class="form-control bg-black text-warning border-secondary" rows="10" style="font-family: 'Consolas', monospace;"></textarea>
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>

                    <div class="form-group d-flex gap-2">
                        <button type="submit" class="btn btn-warning fw-bold px-4"><i class="fas fa-check me-1"></i> Update Vault</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function handleLanguageChange() {
            var dropdown = document.getElementById("languageDropdown");
            var realInput = document.getElementById("Language");

            if (dropdown.value === "custom") {
                realInput.style.display = "block";
                realInput.value = "";
                realInput.focus();
            } else {
                realInput.style.display = "none";
                realInput.value = dropdown.value;
            }
        }

        document.addEventListener("DOMContentLoaded", function() {
            var dropdown = document.getElementById("languageDropdown");
            var realInput = document.getElementById("Language");
            var currentLang = realInput.value;

            if (currentLang) {
                var optionExists = Array.from(dropdown.options).some(opt => opt.value === currentLang);

                if (optionExists) {
                    dropdown.value = currentLang;
                    realInput.style.display = "none";
                } else {
                    dropdown.value = "custom";
                    realInput.style.display = "block";
                }
            } else {
                realInput.value = dropdown.value;
            }
        });
    </script>
}